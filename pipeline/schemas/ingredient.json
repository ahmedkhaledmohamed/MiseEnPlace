{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ingredient",
  "type": "object",
  "required": ["name", "category", "default_unit", "seasons", "is_pantry_staple"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "protein", "vegetable", "fruit", "grain", "dairy",
        "spice", "oil-fat", "sauce-condiment", "herb",
        "legume", "nut-seed", "sweetener", "liquid", "other"
      ]
    },
    "default_unit": {
      "type": "string",
      "enum": ["g", "kg", "ml", "L", "each"]
    },
    "seasons": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["spring", "summer", "fall", "winter", "all"]
      },
      "minItems": 1
    },
    "is_pantry_staple": {
      "type": "boolean"
    },
    "shelf_life_days": {
      "type": "integer",
      "minimum": 1
    },
    "substitutes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ingredient_name", "ratio"],
        "properties": {
          "ingredient_name": { "type": "string" },
          "ratio": { "type": "number", "minimum": 0 },
          "flavor_impact": {
            "type": "string",
            "enum": ["none", "mild", "significant"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "prices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["region", "store_tier", "price", "unit"],
        "properties": {
          "region": { "type": "string" },
          "store_tier": {
            "type": "string",
            "enum": ["budget", "mid", "premium"]
          },
          "price": { "type": "number", "minimum": 0 },
          "unit": { "type": "string" },
          "source": { "type": "string" },
          "last_updated": { "type": "string", "format": "date" }
        }
      }
    }
  }
}
